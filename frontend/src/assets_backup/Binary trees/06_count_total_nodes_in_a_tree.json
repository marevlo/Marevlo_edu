{
  "problem": {
    "id": "binary-tree-count-nodes-001",
    "title": "Count Total Nodes in Binary Tree",
    "description": "Given the root of a binary tree represented as a level-order array (-1 for null), count the total number of nodes using recursive or iterative methods. This allows computing the node count in O(N) time after O(N) tree construction.",
    "examples": [
      {
        "case": "Sample Input",
        "input": {"root": [1,2,3]},
        "output": 3
      },
      {
        "case": "Left Skewed",
        "input": {"root": [1,-1,2,-1,3]},
        "output": 3
      },
      {
        "case": "Balanced Tree",
        "input": {"root": [4,2,6,1,3,5,7]},
        "output": 7
      }
    ],
    "constraints": [
      "0 ≤ number of nodes ≤ 10^5",
      "Node values -10000 ≤ val ≤ 10000",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"root": [], "output": 0},
      {"root": [1], "output": 1},
      {"root": [9999991], "output": 1}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Standard Recursive Node Count",
      "overall_complexity": {"time": "O(N)", "space": "O(H)"},
      "intuition": "Recursively count nodes as 1 + left subtree count + right subtree count. Direct recursion matches the tree definition perfectly.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Overview of Recursive Count",
          "instruction": "Define a recursive function that returns 1 + count(left) + count(right) for any node. After tree build, count is O(N).",
          "examples": [
            {
              "input": "root=[1,2,3]",
              "output": "3",
              "note": "Standard 1 + left + right"
            },
            {
              "input": "root=[1]",
              "output": "1",
              "note": "Base case"
            }
          ],
          "test_cases": [
            {"input": {"root": [1,2,3]}, "output": 3},
            {"input": {"root": [1]}, "output": 1},
            {"input": {"root": [1,-1,2,3]}, "output": 3},
            {"input": {"root": [4,2,6,1,3,5,7]}, "output": 7},
            {"input": {"root": [3,1,4,-1,-1,2,-1]}, "output": 4},
            {"input": {"root": [10,5,15,3,7,-1,18]}, "output": 6},
            {"input": {"root": []}, "output": 0},
            {"input": {"root": [2,1,3]}, "output": 3},
            {"input": {"root": [9,3,20,-1,-1,15,7]}, "output": 5},
            {"input": {"root": [1,2,-1,3,-1,-1,-1]}, "output": 3}
          ]
        },
        {
          "step_id": "L2",
          "title": "Initialize Tree and Result",
          "instruction": "Build the binary tree from level-order array and prepare to return the count.",
          "examples": [
            {
              "input": "root=[1,2,3]",
              "output": {"size": 3},
              "note": "Tree nodes ready"
            },
            {
              "input": "root=[1]",
              "output": {"size": 1},
              "note": "Single node"
            }
          ],
          "test_cases": [
            {"input": {"root": [1,2,3]}, "output": {"size": 3}},
            {"input": {"root": [1]}, "output": {"size": 1}},
            {"input": {"root": [1,-1,2,3]}, "output": {"size": 3}},
            {"input": {"root": [4,2,6,1,3,5,7]}, "output": {"size": 7}},
            {"input": {"root": [3,1,4,-1,-1,2,-1]}, "output": {"size": 4}},
            {"input": {"root": [10,5,15,3,7,-1,18]}, "output": {"size": 6}},
            {"input": {"root": []}, "output": {"size": 0}},
            {"input": {"root": [2,1,3]}, "output": {"size": 3}},
            {"input": {"root": [9,3,20,-1,-1,15,7]}, "output": {"size": 5}},
            {"input": {"root": [1,2,-1,3,-1,-1,-1]}, "output": {"size": 3}}
          ]
        },
        {
          "step_id": "L3",
          "title": "Build Tree Structure",
          "instruction": "Construct the binary tree nodes from the level-order array using a queue for parent-child linking.",
          "examples": [
            {
              "input": "root=[1,2,3]",
              "output": {"left":2,"right":3},
              "note": "Tree built"
