{
  "problem": {
    "id": "binary-tree-from-preorder-inorder-001",
    "title": "Construct Binary Tree from Preorder and Inorder Traversal",
    "description": "Given two integer arrays preorder and inorder where preorder is the preorder traversal of a binary tree and inorder is the inorder traversal of the same tree, construct and return the binary tree. Assume that the tree has no duplicate node values. The input is given as two level-order arrays (preorder and inorder) with -1 representing null. Return the constructed tree as a level-order array. This allows reconstruction in O(N) time after O(N) preprocessing.",
    "examples": [
      {
        "case": "Sample Input",
        "input": {"preorder": [3,9,20,15,7], "inorder": [9,3,15,20,7]},
        "output": [3,9,20,null,null,15,7]
      },
      {
        "case": "Single Node",
        "input": {"preorder": [1], "inorder": [1]},
        "output": [1]
      },
      {
        "case": "Left Skewed",
        "input": {"preorder": [1,2,3], "inorder": [3,2,1]},
        "output": [1,2,null,3]
      }
    ],
    "constraints": [
      "0 ≤ number of nodes ≤ 10^5",
      "Node values -10000 ≤ val ≤ 10000",
      "preorder and inorder are permutations of each other",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"preorder": [], "inorder": [], "output": []},
      {"preorder": [1], "inorder": [1], "output": [1]},
      {"preorder": [1,2,null,3], "inorder": [2,1,3], "output": [1,2,null,3]}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Recursive with HashMap for Inorder Indices",
      "overall_complexity": {"time": "O(N)", "space": "O(N)"},
      "intuition": "Use a hashmap to store inorder indices for O(1) lookup of root position. Recursively build left and right subtrees by partitioning the arrays around the root index.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Overview of Recursive Build with HashMap",
          "instruction": "Create a map from value → index in inorder array. Then recursively build: root = preorder[preStart], find its index in inorder, build left and right subtrees with correct ranges.",
          "examples": [
            {
              "input": "preorder=[3,9,20,15,7], inorder=[9,3,15,20,7]",
              "output": "[3,9,20,null,null,15,7]",
              "note": "Root 3 splits correctly"
            },
            {
              "input": "preorder=[1], inorder=[1]",
              "output": "[1]",
              "note": "Single node base"
            }
          ],
          "test_cases": [
            {"input": {"preorder": [3,9,20,15,7], "inorder": [9,3,15,20,7]}, "output": [3,9,20,null,null,15,7]},
            {"input": {"preorder": [1], "inorder": [1]}, "output": [1]},
            {"input": {"preorder": [1,2,3], "inorder": [3,2,1]}, "output": [1,2,null,3]},
            {"input": {"preorder": [4,2,1,3,6,5,7], "inorder": [1,2,3,4,5,6,7]}, "output": [4,2,6,1,3,5,7]},
            {"input": {"preorder": [1,2,4,5,3], "inorder": [4,2,5,1,3]}, "output": [1,2,3,4,5]},
            {"input": {"preorder": [1,2,null,3], "inorder": [2,1,3]}, "output": [1,2,null,3]},
            {"input": {"preorder": [], "inorder": []}, "output": []},
            {"input": {"preorder": [2,1,3], "inorder": [1,2,3]}, "output": [2,1,3]},
            {"input": {"preorder": [9,3,20,15,7], "inorder": [3,9,15,20,7]}, "output": [9,3,20,null,null,15,7]},
            {"input": {"preorder": [1,2,null,3,null,null,null], "inorder": [2,1,3]}, "output": [1,2,null,3]}
          ]
        },
        {
          "step_id": "L2",
          "title": "Build Inorder Index Map",
          "instruction": "Create a hashmap that maps each value in inorder to its index for O(1) root position lookup.",
          "examples": [
            {
              "input": "inorder=[9,3,15,20,7]",
              "output": {"3":1, "9":0, "15":2, "20":3, "7":4},
              "note": "Map ready"
            },
            {
              "input": "inorder=[1]",
              "output": {"1":0},
              "note": "Single entry"
            }
          ],
          "test_cases": [
            {"input": {"inorder": [9,3,15,20,7]}, "output": {"3":1,"9":0,"15":2,"20":3,"7":4}},
            {"input": {"inorder": [1]}, "output": {"1":0}},
            {"input": {"inorder": [3,2,1]}, "output": {"3":0,"2":1,"1":2}},
            {"input": {"inorder": [1,2,3,4,5,6,7]}, "output": {"4":3}},
            {"input": {"inorder": [4,2,5,1,3]}, "output": {"1":3}},
            {"input": {"inorder": [2,1,3]}, "output": {"1":1}},
            {"input": {"inorder": []}, "output": {}},
            {"input": {"inorder": [1,2,3]}, "output": {"2":1}},
            {"input": {"inorder": [3,9,15,20,7]}, "output": {"9":1}},
            {"input": {"inorder": [2,1,3]}, "output": {"2":0}}
          ]
        },
        {
          "step_id": "L3",
          "title": "Recursive Build Function",
          "instruction": "Define build(preStart, preEnd, inStart, inEnd): if ranges invalid return null; root = preorder[preStart]; idx = map[root.val]; build left and right subtrees with correct index ranges.",
          "examples": [
            {
              "input": "pre=[3,9,20,15,7], in=[9,3,15,20,7]",
              "output": "[3,9,20,null,null,15,7]",
              "note": "Correct partitioning"
            },
            {
              "input": "pre=[1], in=[1]",
              "output": "[1]",
              "note": "Leaf case"
            }
          ],
          "test_cases": [
            {"input": {"preorder": [3,9,20,15,7], "inorder": [9,3,15,20,7]}, "output": [3,9,20,null,null,15,7]},
            {"input": {"preorder": [1], "inorder": [1]}, "output": [1]},
            {"input": {"preorder": [1,2,3], "inorder": [3,2,1]}, "output": [1,2,null,3]},
            {"input": {"preorder": [4,2,1,3,6,5,7], "inorder": [1,2,3,4,5,6,7]}, "output": [4,2,6,1,3,5,7]},
            {"input": {"preorder": [1,2,4,5,3], "inorder": [4,2,5,1,3]}, "output": [1,2,3,4,5]},
            {"input": {"preorder": [1,2,null,3], "inorder": [2,1,3]}, "output": [1,2,null,3]},
            {"input": {"preorder": [], "inorder": []}, "output": []},
            {"input": {"preorder": [2,1,3], "inorder": [1,2,3]}, "output": [2,1,3]},
            {"input": {"preorder": [9,3,20,15,7], "inorder": [3,9,15,20,7]}, "output": [9,3,20,null,null,15,7]},
            {"input": {"preorder": [1,2,null,3], "inorder": [2,1,3]}, "output": [1,2,null,3]}
          ]
        },
        {
          "step_id": "L4",
          "title": "Range Partitioning Logic",
          "instruction": "Left subtree: preStart+1 to preStart+1+(idx-inStart)-1; Right: preStart+1+(idx-inStart) to preEnd.",
          "examples": [
            {
              "input": "root idx=1 in [9,3,15,20,7]",
              "output": "left range size=1, right size=2",
              "note": "Correct split"
            },
            {
              "input": "single node",
              "output": "empty subtrees",
              "note": "Base"
            }
          ],
          "test_cases": [
            {"input": {"preorder": [3,9,20,15,7], "inorder": [9,3,15,20,7]}, "output": [3,9,20,null,null,15,7]},
            {"input": {"preorder": [1], "inorder": [1]}, "output": [1]},
            {"input": {"preorder": [1,2,3], "inorder": [3,2,1]}, "output": [1,2,null,3]},
            {"input": {"preorder": [4,2,1,3,6,5,7], "inorder": [1,2,3,4,5,6,7]}, "output": [4,2,6,1,3,5,7]},
            {"input": {"preorder": [1,2,4,5,3], "inorder": [4,2,5,1,3]}, "output": [1,2,3,4,5]},
            {"input": {"preorder": [1,2,null,3], "inorder": [2,1,3]}, "output": [1,2,null,3]},
            {"input": {"preorder": [], "inorder": []}, "output": []},
            {"input": {"preorder": [2,1,3], "inorder": [1,2,3]}, "output": [2,1,3]},
            {"input": {"preorder": [9,3,20,15,7], "inorder": [3,9,15,20,7]}, "output": [9,3,20,null,null,15,7]},
            {"input": {"preorder": [1,2,null,3], "inorder": [2,1,3]}, "output": [1,2,null,3]}
          ]
        },
        {
          "step_id": "L5",
          "title": "Handle Input Arrays",
          "instruction": "Read preorder and inorder arrays, build map, call recursive build with full ranges.",
          "examples": [
            {
              "input": "pre=[3,9,20,15,7], in=[9,3,15,20,7]",
              "output": "[3,9,20,null,null,15,7]",
              "note": "Correct reconstruction"
            },
            {
              "input": "pre=[], in=[]",
              "output": "[]",
              "note": "Empty tree"
            }
          ],
          "test_cases": [
            {"input": {"preorder": [3,9,20,15,7], "inorder": [9,3,15,20,7]}, "output": [3,9,20,null,null,15,7]},
            {"input": {"preorder": [1], "inorder": [1]}, "output": [1]},
            {"input": {"preorder": [1,2,3], "inorder": [3,2,1]}, "output": [1,2,null,3]},
            {"input": {"preorder": [4,2,1,3,6,5,7], "inorder": [1,2,3,4,5,6,7]}, "output": [4,2,6,1,3,5,7]},
