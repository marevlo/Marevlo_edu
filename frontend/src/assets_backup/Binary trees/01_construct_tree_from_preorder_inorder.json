          ]
        },
        {
          "step_id": "L2",
          "title": "Initialize Stack and Pointers",
          "instruction": "Create stack, set preIndex=0, use inorder index map or pointer to track current position.",
          "examples": [
            {
              "input": "pre=[3,9,20,15,7]",
              "output": "stack starts empty",
              "note": "Ready for build"
            },
            {
              "input": "pre=[1]",
              "output": "single push",
              "note": "Init"
            }
          ],
          "test_cases": [
