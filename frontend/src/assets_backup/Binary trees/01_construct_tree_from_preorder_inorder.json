    {
      "approach_id": "A2",
      "name": "Iterative Stack-based Construction",
      "overall_complexity": {"time": "O(N)", "space": "O(N)"},
      "intuition": "Use a stack to simulate the recursion while building the tree by matching preorder and inorder sequences.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Overview of Iterative Stack Construction",
          "instruction": "Use a stack to keep track of the right spine. For each preorder node, pop until inorder match, attach as left/right child accordingly.",
          "examples": [
            {
              "input": "pre=[3,9,20,15,7], in=[9,3,15,20,7]",
              "output": "[3,9,20,null,null,15,7]",
              "note": "Stack simulates recursion"
