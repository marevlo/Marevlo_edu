{
  "problem": {
    "id": "binary-tree-from-postorder-inorder-001",
    "title": "Construct Binary Tree from Postorder and Inorder Traversal",
    "description": "Given two integer arrays postorder and inorder where postorder is the postorder traversal of a binary tree and inorder is the inorder traversal of the same tree, construct and return the binary tree. Assume that the tree has no duplicate node values. The input is given as two level-order arrays (postorder and inorder) with -1 representing null. Return the constructed tree as a level-order array. This allows reconstruction in O(N) time after O(N) preprocessing.",
    "examples": [
      {
        "case": "Sample Input",
        "input": {"postorder": [9,15,7,20,3], "inorder": [9,3,15,20,7]},
        "output": [3,9,20,null,null,15,7]
      },
      {
        "case": "Single Node",
        "input": {"postorder": [1], "inorder": [1]},
        "output": [1]
      },
      {
        "case": "Left Skewed",
        "input": {"postorder": [3,2,1], "inorder": [3,2,1]},
        "output": [1,2,null,3]
      }
    ],
    "constraints": [
      "0 ≤ number of nodes ≤ 10^5",
      "Node values -10000 ≤ val ≤ 10000",
      "postorder and inorder are permutations of each other",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"postorder": [], "inorder": [], "output": []},
      {"postorder": [1], "inorder": [1], "output": [1]},
      {"postorder": [5,4,3,2,1], "inorder": [1,2,3,4,5], "output": [1,2,3,4,5]}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Recursive with HashMap for Inorder Indices",
      "overall_complexity": {"time": "O(N)", "space": "O(N)"},
      "intuition": "Use a hashmap to store inorder indices for O(1) lookup of root position. In postorder, root is always last → take postEnd as root, find its index in inorder, then recursively build right subtree first (postEnd-1 down), then left.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Overview of Recursive Build with HashMap",
          "instruction": "Create a map from value → index in inorder array. Recursively build: root = postorder[postEnd], find its index in inorder, build right subtree first (since postorder has right before root), then left.",
          "examples": [
            {
              "input": "postorder=[9,15,7,20,3], inorder=[9,3,15,20,7]",
              "output": "[3,9,20,null,null,15,7]",
              "note": "Root 3 is last in postorder"
            },
            {
              "input": "postorder=[1], inorder=[1]",
              "output": "[1]",
              "note": "Single node base"
            }
          ],
          "test_cases": [
            {"input": {"postorder": [9,15,7,20,3], "inorder": [9,3,15,20,7]}, "output": [3,9,20,null,null,15,7]},
            {"input": {"postorder": [1], "inorder": [1]}, "output": [1]},
            {"input": {"postorder": [3,2,1], "inorder": [3,2,1]}, "output": [1,2,null,3]},
            {"input": {"postorder": [1,3,2,5,6,7,4], "inorder": [1,2,3,4,5,6,7]}, "output": [4,2,6,1,3,5,7]},
            {"input": {"postorder": [4,5,2,3,1], "inorder": [4,2,5,1,3]}, "output": [1,2,3,4,5]},
            {"input": {"postorder": [3,2,1], "inorder": [2,1,3]}, "output": [1,2,null,3]},
            {"input": {"postorder": [], "inorder": []}, "output": []},
            {"input": {"postorder": [1,3,2], "inorder": [1,2,3]}, "output": [2,1,3]},
            {"input": {"postorder": [15,7,20,3,9], "inorder": [3,9,15,20,7]}, "output": [9,3,20,null,null,15,7]},
            {"input": {"postorder": [3,2,1], "inorder": [2,1,3]}, "output": [1,2,null,3]}
          ]
        },
        {
          "step_id": "L2",
          "title": "Build Inorder Index Map",
          "instruction": "Create a hashmap that maps each value in inorder to its index for O(1) root position lookup.",
          "examples": [
            {
              "input": "inorder=[9,3,15,20,7]",
              "output": {"3":1, "9":0, "15":2, "20":3, "7":4},
              "note": "Map ready"
            },
            {
              "input": "inorder=[1]",
              "output": {"1":0},
              "note": "Single entry"
            }
          ],
          "test_cases": [
            {"input": {"inorder": [9,3,15,20,7]}, "output": {"3":1,"9":0,"15":2,"20":3,"7":4}},
            {"input": {"inorder": [1]}, "output": {"1":0}},
            {"input": {"inorder": [3,2,1]}, "output": {"3":0,"2":1,"1":2}},
            {"input": {"inorder": [1,2,3,4,5,6,7]}, "output": {"4":3}},
            {"input": {"inorder": [4,2,5,1,3]}, "output": {"1":3}},
            {"input": {"inorder": [2,1,3]}, "output": {"1":1}},
            {"input": {"inorder": []}, "output": {}},
            {"input": {"inorder": [1,2,3]}, "output": {"2":1}},
            {"input": {"inorder": [3,9,15,20,7]}, "output": {"9":1}},
            {"input": {"inorder": [2,1,3]}, "output": {"2":0}}
          ]
        },
        {
          "step_id": "L3",
          "title": "Recursive Build Function",
          "instruction": "Define build(postStart, postEnd, inStart, inEnd): if ranges invalid return null; root = postorder[postEnd]; idx = map[root.val]; build right first (postEnd-1 down), then left.",
          "examples": [
            {
              "input": "post=[9,15,7,20,3], in=[9,3,15,20,7]",
              "output": "[3,9,20,null,null,15,7]",
              "note": "Right subtree built first"
            },
            {
              "input": "post=[1], in=[1]",
              "output": "[1]",
              "note": "Leaf case"
            }
          ],
          "test_cases": [
            {"input": {"postorder": [9,15,7,20,3], "inorder": [9,3,15,20,7]}, "output": [3,9,20,null,null,15,7]},
            {"input": {"postorder": [1], "inorder": [1]}, "output": [1]},
            {"input": {"postorder": [3,2,1], "inorder": [3,2,1]}, "output": [1,2,null,3]},
            {"input": {"postorder": [1,3,2,5,6,7,4], "inorder": [1,2,3,4,5,6,7]}, "output": [4,2,6,1,3,5,7]},
            {"input": {"postorder": [4,5,2,3,1], "inorder": [4,2,5,1,3]}, "output": [1,2,3,4,5]},
            {"input": {"postorder": [3,2,1], "inorder": [2,1,3]}, "output": [1,2,null,3]},
            {"input": {"postorder": [], "inorder": []}, "output": []},
            {"input": {"postorder": [1,3,2], "inorder": [1,2,3]}, "output": [2,1,3]},
            {"input": {"postorder": [15,7,20,3,9], "inorder": [3,9,15,20,7]}, "output": [9,3,20,null,null,15,7]},
            {"input": {"postorder": [3,2,1], "inorder": [2,1,3]}, "output": [1,2,null,3]}
          ]
        },
        {
          "step_id": "L4",
          "title": "Right-First Range Partitioning",
          "instruction": "Right subtree: postEnd-1 down to postEnd-(inEnd-idx); Left: remaining before that.",
          "examples": [
            {
              "input": "postEnd=4, idx=1",
              "output": "right size=2, left size=1",
              "note": "Right built first"
            },
            {
              "input": "single node",
              "output": "empty subtrees",
              "note": "Base"
            }
          ],
          "test_cases": [
            {"input": {"postorder": [9,15,7,20,3], "inorder": [9,3,15,20,7]}, "output": [3,9,20,null,null,15,7]},
            {"input": {"postorder": [1], "inorder": [1]}, "output": [1]},
            {"input": {"postorder": [3,2,1], "inorder": [3,2,1]}, "output": [1,2,null,3]},
            {"input": {"postorder": [1,3,2,5,6,7,4], "inorder": [1,2,3,4,5,6,7]}, "output": [4,2,6,1,3,5,7]},
            {"input": {"postorder": [4,5,2,3,1], "inorder": [4,2,5,1,3]}, "output": [1,2,3,4,5]},
            {"input": {"postorder": [3,2,1], "inorder": [2,1,3]}, "output": [1,2,null,3]},
            {"input": {"postorder": [], "inorder": []}, "output": []},
            {"input": {"postorder": [1,3,2], "inorder": [1,2,3]}, "output": [2,1,3]},
            {"input": {"postorder": [15,7,20,3,9], "inorder": [3,9,15,20,7]}, "output": [9,3,20,null,null,15,7]},
            {"input": {"postorder": [3,2,1], "inorder": [2,1,3]}, "output": [1,2,null,3]}
          ]
        },
        {
          "step_id": "L5",
          "title": "Handle Input Arrays",
          "instruction": "Read postorder and inorder arrays, build map, call recursive build with full ranges.",
          "examples": [
            {
              "input": "post=[9,15,7,20,3], in=[9,3,15,20,7]",
              "output": "[3,9,20,null,null,15,7]",
              "note": "Correct reconstruction"
            },
            {
