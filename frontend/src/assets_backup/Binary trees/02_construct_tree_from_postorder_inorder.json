    {
      "approach_id": "A2",
      "name": "Iterative Stack-based Construction",
      "overall_complexity": {"time": "O(N)", "space": "O(N)"},
      "intuition": "Use a stack to simulate the recursion while building the tree by matching postorder and inorder sequences (root is last in postorder).",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Overview of Iterative Stack Construction",
          "instruction": "Use a stack to keep track of the right spine. For each postorder node (processed right-to-left), pop until inorder match, attach as left/right child accordingly.",
          "examples": [
