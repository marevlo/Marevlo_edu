{
  "problem": {
    "id": "find-duplicate-subtrees-001",
    "title": "Find Duplicate Subtrees",
    "description": "Given the root of a binary tree, return all duplicate subtrees. For each kind of duplicate subtrees, return the root node of any one of them. Two trees are duplicates if they have the same structure with the same node values.",
    "examples": [
      {
        "case": "Sample Input 1",
        "input": {"tree": [1,2,3,4,null,2,4,null,null,4]},
        "output": [[2,4],[4]]
      },
      {
        "case": "Sample Input 2",
        "input": {"tree": [2,1,1]},
        "output": [[1]]
      },
      {
        "case": "Sample Input 3",
        "input": {"tree": [0,0,0,0,null,null,0,null,null,null,0]},
        "output": [[0]]
      }
    ],
    "constraints": [
      "1 ≤ number of nodes ≤ 10^4",
      "-200 ≤ Node.val ≤ 200",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"tree": [1], "output": []},
      {"tree": [1,2], "output": []},
      {"tree": [1,1,1], "output": [[1]]},
      {"tree": [1,null,1,null,1], "output": [[1]]},
      {"tree": [1,2,3,4,5,2,3], "output": [[2],[3]]}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Serialization with Hash Map",
      "overall_complexity": {"time": "O(N^2)", "space": "O(N^2)"},
      "intuition": "Serialize each subtree and use a map to count occurrences. Collect roots where count >1.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Define Serialization",
          "instruction": "Postorder serialize: left + right + val.",
          "examples": [
            {
              "input": "tree=[1,2,3]",
              "output": "2!3!1!",
              "note": "Unique delimiter"
            },
            {
              "input": "tree=[1,null,2]",
              "output": "#!2!1!",
              "note": "With null #"
            }
          ],
          "test_cases": [
            {"input": {"tree": [1,2,3]}, "output": "2!#!#!3!#!#!1!#!#!"},
            {"input": {"tree": [1]}, "output": "1!#!#!"},
            {"input": {"tree": [1,2,null,3]}, "output": "2!3!#!#!#!1!#!#!"},
            {"input": {"tree": [1,2,3,4,5,6,7]}, "output": "full serialize"},
            {"input": {"tree": [1,null,2]}, "output": "1!#!2!#!#!"},
            {"input": {"tree": [1,2]}, "output": "1!2!#!#!#!"},
            {"input": {"tree": [1,2,3,null,null,null,4]}, "output": "serialize"},
            {"input": {"tree": [1,2,3,4]}, "output": "serialize"},
            {"input": {"tree": [1,null,2,3]}, "output": "serialize"},
            {"input": {"tree": [1,2,null,3,null,4]}, "output": "serialize"}
          ]
        },
        {
          "step_id": "L2",
          "title": "Traverse Postorder",
          "instruction": "Recur left, right, build serial, map[serial]++.",
          "examples": [
            {
              "input": "left",
              "output": "serial left",
              "note": "Build"
            },
            {
              "input": "right",
              "output": "serial right",
              "note": "Build"
            }
          ],
          "test_cases": [
            {"input": {"tree": [1,2,3]}, "output": {"serials": 3}},
            {"input": {"tree": [1]}, "output": {"serials": 1}},
            {"input": {"tree": [1,2,null,3]}, "output": {"serials": 3}},
            {"input": {"tree": [1,2,3,4,5,6,7]}, "output": {"serials": 7}},
            {"input": {"tree": [1,null,2]}, "output": {"serials": 2}},
            {"input": {"tree": [1,2]}, "output": {"serials": 2}},
            {"input": {"tree": [1,2,3,null,null,null,4]}, "output": {"serials": 4}},
            {"input": {"tree": [1,2,3,4]}, "output": {"serials": 4}},
            {"input": {"tree": [1,null,2,3]}, "output": {"serials": 3}},
            {"input": {"tree": [1,2,null,3,null,4]}, "output": {"serials": 4}}
          ]
        },
        {
          "step_id": "L3",
          "title": "Count Occurrences",
          "instruction": "Use map to count serial frequencies.",
          "examples": [
            {
              "input": "duplicate serial",
              "output": "count2",
              "note": "Dup"
            },
            {
              "input": "unique",
              "output": "count1",
              "note": "No"
            }
          ],
          "test_cases": [
            {"input": {"tree": [1,2,3,2]}, "output": ""},
            {"input": {"tree": [1,2,2]}, "output": ""},
            {"input": {"tree": [1]}, "output": ""},
            {"input": {"tree": [1,2,3]}, "output": ""},
            {"input": {"tree": [1,2,3,4,5,6,7,4,5]}, "output": ""},
            {"input": {"tree": [1,null,2, null,2]}, "output": ""},
            {"input": {"tree": [1,2,2]}, "output": ""},
            {"input": {"tree": [1,2,3,null,null,2,3]}, "output": ""},
            {"input": {"tree": [1,2,3,4,4]}, "output": ""},
            {"input": {"tree": [1,null,2,3,3]}, "output": ""}
          ]
        },
        {
          "step_id": "L4",
          "title": "Collect Duplicate Roots",
          "instruction": "If count==2, add root to result (once per serial).",
          "examples": [
            {
              "input": "count>1",
              "output": "add",
              "note": "Dup"
            },
            {
              "input": "multiple dups",
              "output": "add each type",
              "note": "Unique"
            }
          ],
          "test_cases": [
            {"input": {"tree": [1,2,3,2]}, "output": [[2]]},
            {"input": {"tree": [1,2,2]}, "output": [[2]]},
            {"input": {"tree": [1]}, "output": []},
            {"input": {"tree": [1,2,3]}, "output": []},
            {"input": {"tree": [1,2,3,4,5,6,7,4,5]}, "output": [[4,5]]},
            {"input": {"tree": [1,null,2, null,2]}, "output": [[2]]},
            {"input": {"tree": [1,2,2]}, "output": [[2]]},
            {"input": {"tree": [1,2,3,null,null,2,3]}, "output": [[2,3]]},
            {"input": {"tree": [1,2,3,4,4]}, "output": [[4]]},
            {"input": {"tree": [1,null,2,3,3]}, "output": [[3]]}
          ]
        },
        {
          "step_id": "L5",
          "title": "Handle Null in Serial",
          "instruction": "Include # for null to distinguish structures.",
          "examples": [
            {
              "input": "left null",
              "output": "#",
              "note": "Marker"
            },
            {
              "input": "right null",
              "output": "#",
              "note": "Marker"
            }
          ],
          "test_cases": [
            {"input": {"tree": [1,2,null,2]}, "output": [[2]]},
            {"input": {"tree": [1,null,2,null,2]}, "output": [[2]]},
            {"input": {"tree": [1]}, "output": []},
            {"input": {"tree": [1,2,3]}, "output": []},
            {"input": {"tree": [1,2,null,3,2,null,3]}, "output": [[2,null,3]]},
            {"input": {"tree": [1,null,2, null,2]}, "output": [[2]]},
            {"input": {"tree": [1,2,null,2,null]}, "output": [[2]]},
            {"input": {"tree": [1,2,3,null,null,2,3]}, "output": [[2,3]]},
            {"input": {"tree": [1,2,null,4,4]}, "output": [[4]]},
            {"input": {"tree": [1,null,2,3,3]}, "output": [[3]]}
          ]
        },
        {
          "step_id": "L6",
          "title": "Return List of Roots",
          "instruction": "Collect and return the duplicate roots.",
          "examples": [
            {
              "input": "dups",
              "output": "list",
              "note": "Result"
            },
            {
              "input": "no dups",
              "output": "empty",
              "note": "[]"
            }
          ],
          "test_cases": [
            {"input": {"tree": [1,2,3,4,null,2,4,null,null,4]}, "output": [[2,4],[4]]},
            {"input": {"tree": [2,1,1]}, "output": [[1]]},
            {"input": {"tree": [0,0,0,0,null,null,0,null,null,null,0]}, "output": [[0]]},
            {"input": {"tree": [1]}, "output": []},
            {"input": {"tree": [1,2,3]}, "output": []},
            {"input": {"tree": [1,2,2]}, "output": [[2]]},
            {"input": {"tree": [1,2,3,2,3]}, "output": [[2],[3]]},
            {"input": {"tree": [1,2,3,4,4]}, "output": [[4]]},
            {"input": {"tree": [1,1,1,1,1]}, "output": [[1]]},
            {"input": {"tree": [1,2,null,3,null,3]}, "output": [[3]]}
          ]
        }
      ]
    },
    {
      "approach_id": "A2",
      "name": "Tuple Keys in Map",
      "overall_complexity": {"time": "O(N)", "space": "O(N)"},
      "intuition": "Use tuples (left_serial, val, right_serial) as keys in map for counting.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Postorder Recur",
