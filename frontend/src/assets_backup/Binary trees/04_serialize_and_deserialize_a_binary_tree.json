{
  "problem": {
    "id": "binary-tree-serialize-deserialize-001",
    "title": "Serialize and Deserialize Binary Tree",
    "description": "Design an algorithm to serialize and deserialize a binary tree. Serialization is the process of converting the tree into a string representation, and deserialization is the reverse process — reconstructing the original tree from the string. Use level-order traversal with a special marker (e.g., '#') for null nodes. The input tree is given as a level-order array (-1 for null), serialize it to a comma-separated string, then deserialize back to the same level-order array. Both operations should be O(N).",
    "examples": [
      {
        "case": "Sample Input",
        "input": {"root": [1,2,3,null,null,4,5]},
        "output": "1,2,3,#,#,4,5,#,#,#,#"
      },
      {
        "case": "Single Node",
        "input": {"root": [1]},
        "output": "1,#,#"
      },
      {
        "case": "Empty Tree",
        "input": {"root": []},
        "output": "#"
      }
    ],
    "constraints": [
      "0 ≤ number of nodes ≤ 10^5",
      "Node values -10000 ≤ val ≤ 10000",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"root": [], "output": "#"},
      {"root": [1], "output": "1,#,#"},
      {"root": [1,2,null,3,null,4,null,5], "output": "1,2,#,3,#,4,#,5,#,#,#,#"}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Level-Order Serialization (BFS Queue)",
      "overall_complexity": {"time": "O(N)", "space": "O(N)"},
      "intuition": "Use BFS (queue) to traverse level by level. Append node value or '#' for null. During deserialization, use queue to reconstruct tree by assigning children from the string tokens.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Overview of BFS Serialize & Deserialize",
          "instruction": "Serialize: use queue, append val or '#' for null children. Deserialize: split string, use queue to build tree level by level, assign left/right from next tokens.",
          "examples": [
            {
              "input": "root=[1,2,3,null,null,4,5]",
              "output": "1,2,3,#,#,4,5,#,#,#,#",
              "note": "Level-order with null markers"
            },
            {
              "input": "root=[1]",
              "output": "1,#,#",
              "note": "Single node with two null children"
            }
          ],
          "test_cases": [
            {"input": {"root": [1,2,3,null,null,4,5]}, "output": "1,2,3,#,#,4,5,#,#,#,#"},
            {"input": {"root": [1]}, "output": "1,#,#"},
            {"input": {"root": []}, "output": "#"},
            {"input": {"root": [1,2,null,3]}, "output": "1,2,#,3,#,#,#"},
            {"input": {"root": [4,2,6,1,3,5,7]}, "output": "4,2,6,1,3,5,7,#,#,#,#,#,#,#,#,#"},
            {"input": {"root": [3,1,4,null,null,2,null]}, "output": "3,1,4,#,#,2,#,#,#,#,#"},
            {"input": {"root": [10,5,15,3,7,null,18]}, "output": "10,5,15,3,7,#,18,#,#,#,#,#,#,#"},
            {"input": {"root": [2,1,3]}, "output": "2,1,3,#,#,#,#"},
            {"input": {"root": [9,3,20,null,null,15,7]}, "output": "9,3,20,#,#,15,7,#,#,#,#,#,#"},
            {"input": {"root": [1,2,null,3,null,null,null]}, "output": "1,2,#,3,#,#,#,#,#"}
          ]
        },
        {
          "step_id": "L2",
          "title": "Serialize Using BFS Queue",
          "instruction": "Initialize queue with root. While queue not empty, dequeue node: append val or '#'; enqueue non-null children (even if null, append '#').",
          "examples": [
            {
              "input": "root=[1,2,3,null,null,4,5]",
              "output": "1,2,3,#,#,4,5,#,#,#,#",
              "note": "All nulls marked"
            },
            {
              "input": "root=[]",
              "output": "#",
              "note": "Empty tree handling"
            }
          ],
          "test_cases": [
            {"input": {"root": [1,2,3,null,null,4,5]}, "output": "1,2,3,#,#,4,5,#,#,#,#"},
            {"input": {"root": [1]}, "output": "1,#,#"},
            {"input": {"root": []}, "output": "#"},
            {"input": {"root": [1,2,null,3]}, "output": "1,2,#,3,#,#,#"},
            {"input": {"root": [4,2,6,1,3,5,7]}, "output": "4,2,6,1,3,5,7,#,#,#,#,#,#,#,#,#"},
            {"input": {"root": [3,1,4,null,null,2,null]}, "output": "3,1,4,#,#,2,#,#,#,#,#"},
            {"input": {"root": [10,5,15,3,7,null,18]}, "output": "10,5,15,3,7,#,18,#,#,#,#,#,#,#"},
            {"input": {"root": [2,1,3]}, "output": "2,1,3,#,#,#,#"},
            {"input": {"root": [9,3,20,null,null,15,7]}, "output": "9,3,20,#,#,15,7,#,#,#,#,#,#"},
            {"input": {"root": [1,2,null,3,null,null,null]}, "output": "1,2,#,3,#,#,#,#,#"}
          ]
        },
        {
          "step_id": "L3",
          "title": "Build Tree Structure",
          "instruction": "Construct the binary tree nodes from the level-order array using a queue for parent-child linking.",
          "examples": [
            {
              "input": "root=[1,2,3,null,null,4,5]",
              "output": {"left":2,"right":3},
              "note": "Tree built correctly"
            },
            {
              "input": "root=[1]",
              "output": {"left":-1,"right":-1},
              "note": "Null children handled"
            }
          ],
          "test_cases": [
            {"input": {"root": [1,2,3,null,null,4,5]}, "output": {"left_child":2,"right_child":3}},
            {"input": {"root": [1]}, "output": {"left_child":-1,"right_child":-1}},
            {"input": {"root": [1,2,null,3]}, "output": {"left_child":2,"right_child":-1}},
            {"input": {"root": [4,2,6,1,3,5,7]}, "output": {"left_child":2,"right_child":6}},
            {"input": {"root": [3,1,4,null,null,2,null]}, "output": {"left_child":1,"right_child":4}},
            {"input": {"root": [10,5,15,3,7,null,18]}, "output": {"left_child":5,"right_child":15}},
            {"input": {"root": []}, "output": {"left_child":-1,"right_child":-1}},
            {"input": {"root": [2,1,3]}, "output": {"left_child":1,"right_child":3}},
            {"input": {"root": [9,3,20,null,null,15,7]}, "output": {"left_child":3,"right_child":20}},
            {"input": {"root": [1,2,null,3,null,null,null]}, "output": {"left_child":2,"right_child":-1}}
          ]
        },
        {
          "step_id": "L4",
          "title": "Deserialize Using Queue",
          "instruction": "Split string into list. Create root from first token. Use queue to assign children: for each node, take next two tokens as left/right (if not '#').",
          "examples": [
            {
              "input": "serialized=1,2,3,#,#,4,5,#,#,#,#",
              "output": "[1,2,3,null,null,4,5]",
              "note": "Reconstructed correctly"
            },
            {
              "input": "serialized=1,#,#",
              "output": "[1]",
              "note": "Single node"
            }
          ],
          "test_cases": [
            {"input": {"serialized": "1,2,3,#,#,4,5,#,#,#,#"}, "output": [1,2,3,null,null,4,5]},
            {"input": {"serialized": "1,#,#"}, "output": [1]},
            {"input": {"serialized": "#"}, "output": []},
            {"input": {"serialized": "1,2,#,3,#,#,#"}, "output": [1,2,null,3]},
            {"input": {"serialized": "4,2,6,1,3,5,7,#,#,#,#,#,#,#,#,#"}, "output": [4,2,6,1,3,5,7]},
            {"input": {"serialized": "3,1,4,#,#,2,#,#,#,#,#"}, "output": [3,1,4,null,null,2,null]},
            {"input": {"serialized": "10,5,15,3,7,#,18,#,#,#,#,#,#,#"}, "output": [10,5,15,3,7,null,18]},
            {"input": {"serialized": "2,1,3,#,#,#,#"}, "output": [2,1,3]},
            {"input": {"serialized": "9,3,20,#,#,15,7,#,#,#,#,#,#"}, "output": [9,3,20,null,null,15,7]},
            {"input": {"serialized": "1,2,#,3,#,#,#,#,#"}, "output": [1,2,null,3]}
          ]
        },
        {
          "step_id": "L5",
          "title": "Handle Serialization/Deserialization Input",
          "instruction": "Read level-order array → serialize to string → deserialize back to same level-order array.",
          "examples": [
            {
              "input": "root=[1,2,3,null,null,4,5]",
              "output": "1,2,3,#,#,4,5,#,#,#,#",
              "note": "Round-trip success"
            },
            {
              "input": "root=[]",
              "output": "#",
              "note": "Empty tree"
            }
          ],
          "test_cases": [
            {"input": {"root": [1,2,3,null,null,4,5]}, "output": "1,2,3,#,#,4,5,#,#,#,#"},
            {"input": {"root": [1]}, "output": "1,#,#"},
            {"input": {"root": []}, "output": "#"},
            {"input": {"root": [1,2,null,3]}, "output": "1,2,#,3,#,#,#"},
            {"input": {"root": [4,2,6,1,3,5,7]}, "output": "4,2,6,1,3,5,7,#,#,#,#,#,#,#,#,#"},
            {"input": {"root": [3,1,4,null,null,2,null]}, "output": "3,1,4,#,#,2,#,#,#,#,#"},
            {"input": {"root": [10,5,15,3,7,null,18]}, "output": "10,5,15,3,7,#,18,#,#,#,#,#,#,#"},
            {"input": {"root": [2,1,3]}, "output": "2,1,3,#,#,#,#"},
            {"input": {"root": [9,3,20,null,null,15,7]}, "output": "9,3,20,#,#,15,7,#,#,#,#,#,#"},
            {"input": {"root": [1,2,null,3,null,null,null]}, "output": "1,2,#,3,#,#,#,#,#"}
          ]
        },
        {
          "step_id": "L6",
          "title": "Output Serialized String or Reconstructed Tree",
          "instruction": "For serialization output the comma-separated string; for deserialization output the level-order array.",
          "examples": [
            {
              "input": "root=[1,2,3,null,null,4,5]",
              "output": "1,2,3,#,#,4,5,#,#,#,#",
              "note": "Exact serialization"
