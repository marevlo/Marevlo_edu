{
  "problem": {
    "id": "largest-bst-subtree-001",
    "title": "Find Largest BST Subtree in Binary Tree",
    "description": "Given the root of a binary tree, find the largest subtree that is a Binary Search Tree (BST). Return the size (number of nodes) of the largest BST subtree.",
    "examples": [
      {
        "case": "Sample Input 1",
        "input": {"tree": [10,5,15,1,8,null,7]},
        "output": 3
      },
      {
        "case": "Sample Input 2",
        "input": {"tree": [5,3,6,2,4,null,7]},
        "output": 3
      },
      {
        "case": "Sample Input 3",
        "input": {"tree": [1,2,3]},
        "output": 3
      }
    ],
    "constraints": [
      "1 ≤ number of nodes ≤ 10^4",
      "-10^4 ≤ Node.val ≤ 10^4",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"tree": [1], "output": 1},
      {"tree": [1,2], "output": 2},
      {"tree": [3,2,1], "output": 1},
      {"tree": [1,null,2,null,null,null,3], "output": 3},
      {"tree": [5,6,3,7,4,2,1], "output": 1}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Bottom-Up Recursion with Min-Max",
      "overall_complexity": {"time": "O(N)", "space": "O(H)"},
      "intuition": "For each subtree, check if it's a BST by verifying min-max ranges, compute size if yes, track global max.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Define Return Structure",
          "instruction": "Each recur returns {isBST, size, min, max}.",
          "examples": [
            {
              "input": "leaf",
              "output": "true,1,val,val",
              "note": "Base"
            },
            {
              "input": "null",
              "output": "true,0,INF,-INF",
              "note": "Handle"
            }
          ],
          "test_cases": [
            {"input": {"node": 1}, "output": {"isBST": true, "size": 1, "min": 1, "max": 1}},
            {"input": {"node": null}, "output": {"isBST": true, "size": 0, "min": "INF", "max": "-INF"}},
            {"input": {"tree": [2,1,3]}, "output": {"isBST": true, "size": 3, "min": 1, "max": 3}},
            {"input": {"tree": [2,3,1]}, "output": {"isBST": false}},
            {"input": {"tree": [5,3,6]}, "output": {"isBST": true, "size": 3, "min": 3, "max": 6}},
            {"input": {"tree": [1,2]}, "output": {"isBST": true, "size": 2, "min": 1, "max": 2}},
            {"input": {"tree": [3,2,1]}, "output": {"isBST": false}},
            {"input": {"tree": [4,2,5,1,3]}, "output": {"isBST": true, "size": 5}},
            {"input": {"tree": [1,null,2]}, "output": {"isBST": true, "size": 2, "min": 1, "max": 2}},
            {"input": {"tree": [10,5,15]}, "output": {"isBST": true, "size": 3, "min": 5, "max": 15}}
          ]
        },
        {
          "step_id": "L2",
          "title": "Recur Left and Right",
          "instruction": "Get left_info = recur(left), right_info = recur(right).",
          "examples": [
            {
              "input": "left",
              "output": "left_info",
              "note": "Sub"
            },
            {
              "input": "right",
              "output": "right_info",
              "note": "Sub"
            }
          ],
          "test_cases": [
            {"input": {"tree": [10,5,15,1,8,null,7]}, "output": true},
            {"input": {"tree": [1]}, "output": true},
            {"input": {"tree": [5,3,6,2,4,null,7]}, "output": true},
            {"input": {"tree": [1,2,3]}, "output": true},
            {"input": {"tree": [3,2,1]}, "output": true},
            {"input": {"tree": [1,null,2]}, "output": true},
            {"input": {"tree": [1,2]}, "output": true},
            {"input": {"tree": [5,6,3]}, "output": true},
            {"input": {"tree": [4,2,5,1,3]}, "output": true},
            {"input": {"tree": []}, "output": true}
          ]
        },
        {
          "step_id": "L3",
          "title": "Check BST Condition",
          "instruction": "If left.isBST and right.isBST and root.val > left.max and root.val < right.min.",
          "examples": [
            {
              "input": "valid",
              "output": "true",
              "note": "BST"
            },
            {
              "input": "invalid",
              "output": "false",
              "note": "Not"
            }
          ],
          "test_cases": [
            {"input": {"tree": [2,1,3]}, "output": true},
            {"input": {"tree": [2,3,1]}, "output": false},
            {"input": {"tree": [5,3,6]}, "output": true},
            {"input": {"tree": [5,6,3]}, "output": false},
            {"input": {"tree": [1,2]}, "output": true},
            {"input": {"tree": [3,2,1]}, "output": false},
            {"input": {"tree": [4,2,5,1,3]}, "output": true},
            {"input": {"tree": [1,null,2]}, "output": true},
            {"input": {"tree": [10,5,15]}, "output": true},
            {"input": {"tree": [10,15,5]}, "output": false}
          ]
        },
        {
          "step_id": "L4",
          "title": "Compute Size",
          "instruction": "If BST, size = left.size + right.size +1, update global max.",
          "examples": [
            {
              "input": "BST",
              "output": "sum +1",
              "note": "Size"
            },
            {
              "input": "not",
              "output": "max(left.size, right.size)",
              "note": "Sub max"
            }
          ],
          "test_cases": [
            {"input": {"tree": [10,5,15,1,8,null,7]}, "output": 3},
            {"input": {"tree": [5,3,6,2,4,null,7]}, "output": 3},
            {"input": {"tree": [1,2,3]}, "output": 3},
            {"input": {"tree": [1]}, "output": 1},
            {"input": {"tree": [3,2,1]}, "output": 1},
            {"input": {"tree": [1,null,2]}, "output": 2},
            {"input": {"tree": [1,2]}, "output": 2},
            {"input": {"tree": [4,2,5,1,3]}, "output": 5},
            {"input": {"tree": [5,6,3]}, "output": 1},
            {"input": {"tree": []}, "output": 0}
          ]
        },
        {
          "step_id": "L5",
          "title": "Set Min Max",
          "instruction": "Min = min(left.min, val, right.min), max similar.",
          "examples": [
            {
              "input": "subtree",
              "output": "range",
              "note": "For parent"
            },
            {
              "input": "not BST",
              "output": "still set for info",
              "note": "Propagate"
            }
          ],
          "test_cases": [
            {"input": {"tree": [2,1,3]}, "output": {"min":1,"max":3}},
            {"input": {"tree": [2,3,1]}, "output": {"min":1,"max":3}},
            {"input": {"tree": [5,3,6]}, "output": {"min":3,"max":6}},
            {"input": {"tree": [1,2]}, "output": {"min":1,"max":2}},
            {"input": {"tree": [3,2,1]}, "output": {"min":1,"max":3}},
            {"input": {"tree": [1,null,2]}, "output": {"min":1,"max":2}},
            {"input": {"tree": [4,2,5,1,3]}, "output": {"min":1,"max":5}},
            {"input": {"tree": [10,5,15]}, "output": {"min":5,"max":15}},
            {"input": {"tree": [5,6,3]}, "output": {"min":3,"max":6}},
            {"input": {"tree": [1]}, "output": {"min":1,"max":1}}
          ]
        },
        {
          "step_id": "L6",
          "title": "Return Info",
          "instruction": "Return the struct for parent.",
          "examples": [
            {
              "input": "BST",
              "output": "true size min max",
              "note": "Yes"
            },
            {
              "input": "not",
              "output": "false max_sub min max",
              "note": "No"
            }
          ],
          "test_cases": [
            {"input": {"tree": [10,5,15,1,8,null,7]}, "output": 3},
            {"input": {"tree": [5,3,6,2,4,null,7]}, "output": 3},
            {"input": {"tree": [1,2,3]}, "output": 3},
            {"input": {"tree": [1]}, "output": 1},
            {"input": {"tree": [3,2,1]}, "output": 1},
            {"input": {"tree": [1,null,2]}, "output": 2},
            {"input": {"tree": [1,2]}, "output": 2},
            {"input": {"tree": [4,2,5,1,3]}, "output": 5},
            {"input": {"tree": [5,6,3]}, "output": 1},
            {"input": {"tree": []}, "output": 0}
          ]
        }
      ]
    },
