{
  "problem": {
    "id": "convert-binary-tree-to-dll-inorder-001",
    "title": "Convert Binary Tree to Doubly Linked List (Inorder)",
    "description": "Given a binary tree, convert it to a doubly linked list using inorder traversal. The left and right pointers in nodes are to be used as previous and next pointers respectively in the converted DLL. The order of nodes in DLL must be the same as inorder of the given binary tree. The first node of inorder traversal (leftmost node in BT) must be the head node of the DLL.",
    "examples": [
      {
        "case": "Sample Input 1",
        "input": {"tree": [10,12,15,25,30,36]},
        "output": [25,12,30,10,36,15]
      },
      {
        "case": "Sample Input 2",
        "input": {"tree": [4,2,5,1,3]},
        "output": [1,2,3,4,5]
      },
      {
        "case": "Sample Input 3",
        "input": {"tree": [1,null,2]},
        "output": [1,2]
      }
    ],
    "constraints": [
      "1 ≤ number of nodes ≤ 1000",
      "-1000 ≤ Node.val ≤ 1000",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"tree": [], "output": []},
      {"tree": [1], "output": [1]},
      {"tree": [1,2], "output": [2,1]},
      {"tree": [1,null,2,null,null,null,3], "output": [1,2,3]},
      {"tree": [5,3,6,2,4,null,7], "output": [2,3,4,5,6,7]}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Recursive Inorder with Prev Pointer",
      "overall_complexity": {"time": "O(N)", "space": "O(H)"},
      "intuition": "Perform inorder traversal recursively, maintain a prev pointer to link nodes.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Initialize Head and Prev",
          "instruction": "Set head = null, prev = null as global or ref.",
          "examples": [
            {
              "input": "start",
              "output": "null",
              "note": "Init"
            },
            {
              "input": "empty tree",
              "output": "null",
              "note": "No change"
            }
          ],
          "test_cases": [
            {"input": {"tree": [10,12,15,25,30,36]}, "output": {"init": true}},
            {"input": {"tree": []}, "output": {"init": true}},
            {"input": {"tree": [1]}, "output": {"init": true}},
            {"input": {"tree": [4,2,5,1,3]}, "output": {"init": true}},
            {"input": {"tree": [1,null,2]}, "output": {"init": true}},
            {"input": {"tree": [1,2]}, "output": {"init": true}},
            {"input": {"tree": [5,3,6,2,4,null,7]}, "output": {"init": true}},
            {"input": {"tree": [1,2,3,4]}, "output": {"init": true}},
            {"input": {"tree": [1,null,2,3]}, "output": {"init": true}},
            {"input": {"tree": [1,2,null,3,null,4]}, "output": {"init": true}}
          ]
        },
        {
          "step_id": "L2",
          "title": "Recur on Left",
          "instruction": "Recur left subtree first.",
          "examples": [
            {
              "input": "left exists",
              "output": "process left",
              "note": "Inorder"
            },
            {
              "input": "no left",
              "output": "skip",
              "note": "Null"
            }
          ],
          "test_cases": [
            {"input": {"tree": [10,12,15,25,30,36]}, "output": true},
            {"input": {"tree": [1]}, "output": true},
