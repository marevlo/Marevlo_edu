            {"input": {"main_str": "3,4,1,#,#,2,#,0,#,#,5,#,#", "sub_str": "4,1,#,#,2,#,#"}, "output": false},
            {"input": {"main_str": "1,2,#,#,3,#,#", "sub_str": "2,#,#"}, "output": true},
            {"input": {"main_str": "1,#,#", "sub_str": "1,#,#"}, "output": true},
