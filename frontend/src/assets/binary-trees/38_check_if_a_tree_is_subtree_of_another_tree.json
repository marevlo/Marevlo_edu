{
  "problem": {
    "id": "check-subtree-binary-tree-001",
    "title": "Check if a Tree is a Subtree of Another Tree",
    "description": "Given two binary trees root and subRoot, check if subRoot is a subtree of root. A subtree means a tree consisting of a node in root and all of its descendants.",
    "examples": [
      {
        "case": "Sample Input 1",
        "input": {"root": [3,4,5,1,2], "subRoot": [4,1,2]},
        "output": true
      },
      {
        "case": "Sample Input 2",
        "input": {"root": [3,4,5,1,2,null,null,null,null,0], "subRoot": [4,1,2]},
        "output": false
      },
      {
        "case": "Sample Input 3",
        "input": {"root": [1,2,3], "subRoot": [2]},
        "output": true
      }
    ],
    "constraints": [
      "1 ≤ number of nodes in root ≤ 1000",
      "1 ≤ number of nodes in subRoot ≤ 1000",
      "-10^4 ≤ Node.val ≤ 10^4",
      "Time limit: 1-2 seconds"
    ],
    "edge_cases": [
      {"root": [], "subRoot": [], "output": true},
      {"root": [1], "subRoot": [1], "output": true},
      {"root": [1,2], "subRoot": [3], "output": false},
      {"root": [1,null,2,null,null,null,3], "subRoot": [2,null,3], "output": true},
      {"root": [1,2,3,4,5,6,7], "subRoot": [2,4,5], "output": true}
    ]
  },
  "solution_approaches": [
    {
      "approach_id": "A1",
      "name": "Recursive Check",
      "overall_complexity": {"time": "O(M*N)", "space": "O(max(H1,H2))"},
      "intuition": "Traverse the main tree, at each node check if it matches the sub tree by comparing structures and values recursively.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Define Identical Trees Function",
          "instruction": "Create a helper to check if two trees are identical: same values and structures.",
          "examples": [
            {
              "input": "t1=[1,2,3], t2=[1,2,3]",
              "output": "true",
              "note": "Same"
            },
            {
              "input": "t1=[1,2], t2=[1,null,2]",
              "output": "false",
              "note": "Different"
            }
          ],
          "test_cases": [
            {"input": {"t1": [1,2,3], "t2": [1,2,3]}, "output": true},
            {"input": {"t1": [1,2,3], "t2": [1,3,2]}, "output": false},
            {"input": {"t1": [1], "t2": [1]}, "output": true},
            {"input": {"t1": [], "t2": []}, "output": true},
            {"input": {"t1": [1,2], "t2": [1,null,2]}, "output": false},
            {"input": {"t1": [1,null,2], "t2": [1,null,2]}, "output": true},
            {"input": {"t1": [1,2,3,4], "t2": [1,2,3,4]}, "output": true},
            {"input": {"t1": [1,2,3,null,4], "t2": [1,2,3]}, "output": false},
            {"input": {"t1": [1,null,2,3], "t2": [1,null,2,3]}, "output": true},
            {"input": {"t1": [1,2,null,3,null,4], "t2": [2,null,3,null,4]}, "output": true}
          ]
        },
        {
          "step_id": "L2",
          "title": "Traverse Main Tree",
          "instruction": "Recur on root, if match or left or right has match.",
          "examples": [
            {
              "input": "root matches",
              "output": "true",
              "note": "Direct"
            },
            {
              "input": "sub in left",
              "output": "true",
              "note": "Recur"
            }
          ],
          "test_cases": [
            {"input": {"root": [3,4,5,1,2], "sub": [4,1,2]}, "output": true},
            {"input": {"root": [3,4,5,1,2,null,null,null,null,0], "sub": [4,1,2]}, "output": false},
            {"input": {"root": [1,2,3], "sub": [2]}, "output": true},
            {"input": {"root": [1], "sub": [1]}, "output": true},
            {"input": {"root": [], "sub": []}, "output": true},
            {"input": {"root": [1,2], "sub": [3]}, "output": false},
            {"input": {"root": [1,null,2,null,null,null,3], "sub": [2,null,3]}, "output": true},
            {"input": {"root": [1,2,3,4,5,6,7], "sub": [2,4,5]}, "output": true},
            {"input": {"root": [1,2,3,4,5], "sub": [3, null, null]}, "output": false},
            {"input": {"root": [1,2,null,3,null,4], "sub": [3,null,4]}, "output": true}
          ]
        },
        {
          "step_id": "L3",
          "title": "Handle Null Cases",
          "instruction": "If root null and sub not, false; if sub null true (empty subtree).",
          "examples": [
            {
              "input": "root null sub not",
              "output": "false",
              "note": "No"
            },
            {
              "input": "sub null",
              "output": "true",
              "note": "Yes"
            }
          ],
          "test_cases": [
            {"input": {"root": null, "sub": [1]}, "output": false},
            {"input": {"root": [1], "sub": null}, "output": true},
            {"input": {"root": null, "sub": null}, "output": true},
            {"input": {"root": [1,2,3], "sub": null}, "output": true},
            {"input": {"root": null, "sub": [1,2]}, "output": false},
            {"input": {"root": [1,null,2], "sub": null}, "output": true},
            {"input": {"root": [1,2,3,4], "sub": null}, "output": true},
            {"input": {"root": null, "sub": [1,2,3]}, "output": false},
            {"input": {"root": [1,null,2,3], "sub": null}, "output": true},
            {"input": {"root": null, "sub": [1,2,null,3,null,4]}, "output": false}
          ]
        },
        {
          "step_id": "L4",
          "title": "Identical Check Recursive",
          "instruction": "In identical: if both null true, one null false, vals differ false, recur lefts and rights.",
          "examples": [
            {
              "input": "vals same structs same",
              "output": "true",
              "note": "Match"
            },
            {
              "input": "diff val",
              "output": "false",
              "note": "No"
            }
          ],
          "test_cases": [
            {"input": {"t1": [1,2,3], "t2": [1,2,3]}, "output": true},
            {"input": {"t1": [1,2,3], "t2": [1,3,2]}, "output": false},
            {"input": {"t1": [1], "t2": [1]}, "output": true},
            {"input": {"t1": null, "t2": null}, "output": true},
            {"input": {"t1": [1,2], "t2": [1,null,2]}, "output": false},
            {"input": {"t1": [1,null,2], "t2": [1,null,2]}, "output": true},
            {"input": {"t1": [1,2,3,4], "t2": [1,2,3,4]}, "output": true},
            {"input": {"t1": [1,2,3,null,4], "t2": [1,2,3]}, "output": false},
            {"input": {"t1": [1,null,2,3], "t2": [1,null,2,3]}, "output": true},
            {"input": {"t1": [1,2,null,3,null,4], "t2": [2,null,3,null,4]}, "output": true}
          ]
        },
        {
          "step_id": "L5",
          "title": "Combine Results",
          "instruction": "Return identical(root, sub) or isSubtree(root.left, sub) or isSubtree(root.right, sub)",
          "examples": [
            {
              "input": "match in right",
              "output": "true",
              "note": "Or"
            },
            {
              "input": "no match",
              "output": "false",
              "note": "All false"
            }
          ],
          "test_cases": [
            {"input": {"root": [3,4,5,1,2], "sub": [4,1,2]}, "output": true},
            {"input": {"root": [3,4,5,1,2,null,null,null,null,0], "sub": [4,1,2]}, "output": false},
            {"input": {"root": [1,2,3], "sub": [2]}, "output": true},
            {"input": {"root": [1], "sub": [1]}, "output": true},
            {"input": {"root": [], "sub": []}, "output": true},
            {"input": {"root": [1,2], "sub": [3]}, "output": false},
            {"input": {"root": [1,null,2,null,null,null,3], "sub": [2,null,3]}, "output": true},
            {"input": {"root": [1,2,3,4,5,6,7], "sub": [2,4,5]}, "output": true},
            {"input": {"root": [1,2,3,4,5], "sub": [3]}, "output": true},
            {"input": {"root": [1,2,null,3,null,4], "sub": [3,null,4]}, "output": true}
          ]
        },
        {
          "step_id": "L6",
          "title": "Return Boolean",
          "instruction": "The result is whether sub is subtree.",
          "examples": [
            {
              "input": "yes",
              "output": "true",
              "note": "Yes"
            },
            {
              "input": "no",
              "output": "false",
              "note": "No"
            }
          ],
          "test_cases": [
            {"input": {"root": [3,4,5,1,2], "sub": [4,1,2]}, "output": true},
            {"input": {"root": [3,4,5,1,2,null,null,null,null,0], "sub": [4,1,2]}, "output": false},
            {"input": {"root": [1,2,3], "sub": [2]}, "output": true},
            {"input": {"root": [1], "sub": [1]}, "output": true},
            {"input": {"root": [], "sub": []}, "output": true},
            {"input": {"root": [1,2], "sub": [3]}, "output": false},
            {"input": {"root": [1,null,2,null,null,null,3], "sub": [2,null,3]}, "output": true},
            {"input": {"root": [1,2,3,4,5,6,7], "sub": [2,4,5]}, "output": true},
            {"input": {"root": [1,2,3,4,5], "sub": [3]}, "output": true},
            {"input": {"root": [1,2,null,3,null,4], "sub": [3,null,4]}, "output": true}
          ]
        }
      ]
    },
    {
      "approach_id": "A2",
      "name": "Tree Serialization",
      "overall_complexity": {"time": "O(M+N)", "space": "O(M+N)"},
      "intuition": "Serialize both trees to strings and check if sub serialization is substring of main.",
      "ladders": [
        {
          "step_id": "L1",
          "title": "Define Serialization",
          "instruction": "Preorder traversal with markers for null.",
          "examples": [
            {
              "input": "tree=[1,2,3]",
              "output": "1,2,#,#,3,#,#",
              "note": "String"
            },
            {
              "input": "tree=[1,null,2]",
              "output": "1,#,2,#,#",
              "note": "With nulls"
            }
          ],
          "test_cases": [
            {"input": {"tree": [1,2,3]}, "output": "1,2,#,#,3,#,#"},
            {"input": {"tree": [1]}, "output": "1,#,#"},
            {"input": {"tree": [1,2,null,3]}, "output": "1,2,3,#,#,#,#"},
            {"input": {"tree": [1,2,3,4,5,6,7]}, "output": "1,2,4,#,#,5,#,#,3,6,#,#,7,#,#"},
            {"input": {"tree": [1,null,2]}, "output": "1,#,2,#,#"},
            {"input": {"tree": [1,2]}, "output": "1,2,#,#,#"},
            {"input": {"tree": [1,2,3,null,null,null,4]}, "output": "1,2,#,#,3,#,4,#,#"},
            {"input": {"tree": [1,2,3,4]}, "output": "1,2,4,#,#,#,3,#,#"},
            {"input": {"tree": [1,null,2,3]}, "output": "1,#,2,3,#,#,#"},
            {"input": {"tree": [1,2,null,3,null,4]}, "output": "1,2,#,3,#,4,#,#,#"}
          ]
        },
        {
          "step_id": "L2",
          "title": "Serialize Main Tree",
          "instruction": "Build string for root.",
          "examples": [
            {
              "input": "main",
              "output": "full string",
              "note": "Main"
            },
            {
              "input": "empty",
              "output": "",
              "note": "Null"
            }
          ],
          "test_cases": [
            {"input": {"root": [3,4,5,1,2]}, "output": "3,4,1,#,#,2,#,#,5,#,#"},
