# Local development: uses Vite proxy (routes /api -> http://localhost:8000)
VITE_API_URL=/api

# Production (AWS): the SPA and API are served from the SAME origin
# (CloudFront: default -> S3, /api/* -> ALB), so this stays /api in prod too.
# VITE_API_URL=/api

# Firebase (from Firebase Console -> Project Settings -> Your apps -> Config)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
