# ── Environment ─────────────────────────────────────────────────────
# Values: dev | test | staging | prod
ENV=dev
DEBUG=false
APP_NAME="Marevlo API"
APP_VERSION=1.0.0

# ── Database ────────────────────────────────────────────────────────
# Native dev: localhost.  Inside docker compose: postgres host name.
DATABASE_URL=postgresql+psycopg2://marevlo:marevlo@localhost:5432/marevlo_dev
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_REQUIRED=true

# ── JWT ────────────────────────────────────────────────────────────
# In prod, set this to a 32+ random char string from Secrets Manager.
# Must match the JWT_SECRET in the jupyterhub service.
JWT_SECRET=local-dev-secret-replace-in-prod-32chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,https://marevlo.com,https://www.marevlo.com

# ── AWS / S3 ───────────────────────────────────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET=marevlo-user-uploads-dev
# Leave empty for real AWS; set to MinIO endpoint for local dev
S3_ENDPOINT_URL=

# ── Email (use AWS SES SMTP in prod) ──────────────────────────────
SMTP_HOST=email-smtp.ap-south-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@marevlo.com
SMTP_USE_TLS=true

# ── Firebase (Google login) ───────────────────────────────────────
# Either FIREBASE_CREDENTIALS_JSON (env var with the full JSON) — preferred
# in prod via Secrets Manager — OR FIREBASE_CREDENTIALS_PATH (file path).
# In docker compose the secrets/ directory is mounted to /run/secrets, so
# point this at /run/secrets/firebase-credentials.json there.
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=

# ── External services ─────────────────────────────────────────────
# IDE runner exposes POST /run on :4002.  Native dev: localhost.
# Inside docker compose: the runner service hostname.
IDE_RUNNER_URL=http://localhost:4002
# JupyterHub base URL — backend mints a token and redirects user to
# {NOTEBOOK_BASE_URL}/hub/login?token=...
NOTEBOOK_BASE_URL=http://localhost:8001

# ── Trust ALB / CloudFront for X-Forwarded-For ───────────────────
# In production, set to the VPC CIDRs that ALB sits in.
# Format: comma-separated CIDRs.
TRUSTED_PROXIES=

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text  # 'json' in prod for CloudWatch

# ── Sentry (optional) ─────────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
