# ════════════════════════════════════════════════════════════════════════════
# Marevlo — root .env (read by docker-compose.yml)
#
# Copy this to `.env` and fill in real values before `docker compose up`.
# ════════════════════════════════════════════════════════════════════════════

# ── Environment ─────────────────────────────────────────────────────────────
ENV=prod          # dev | test | staging | prod
MAREVLO_DEBUG=false
LOG_FORMAT=json   # json for prod (CloudWatch), text for local dev
RATE_LIMIT_ENABLED=true

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=marevlo_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=marevlo_db
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PORT=6379
# Required: any strong random string (e.g. `openssl rand -hex 32`).
REDIS_PASSWORD=changeme

# ── Backend (FastAPI) ───────────────────────────────────────────────────────
BACKEND_PORT=8000
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS
JWT_ALGORITHM=HS256
TRUSTED_PROXIES=127.0.0.1/32

# CORS — every origin that should be allowed to call the API.
# Local dev (Vite): http://localhost:5173
# Vercel:           https://marevlo.vercel.app
CORS_ORIGINS=https://marevlo.vercel.app,http://localhost:5173,http://localhost:3000

# ── JupyterHub (the public URL the backend embeds in /notebook/launch) ─────
JUPYTERHUB_PORT=8001
NOTEBOOK_BASE_URL=http://localhost:8001   # in prod: https://notebook.<your-domain>

# ── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=true

# ── MIRA (AI tutor module) ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QDRANT_PORT=6333
MIRA_ADMIN_TOKEN=
MIRA_ENABLED_FOR_ALL=false
MIRA_ENABLED_USER_IDS=
MIRA_ADMIN_USER_IDS=
MIRA_GLOBAL_KILL=false
MIRA_DEV_MODE_ALLOW_HEADER_UID=false

# ── Firebase ────────────────────────────────────────────────────────────────
# Drop the service-account JSON at `./secrets/firebase-credentials.json`.
# It is mounted into the api container at /run/secrets/firebase-credentials.json.

# ── Frontend (NOT used by docker compose; lives in frontend/.env.local) ────
# VITE_API_URL=http://localhost:8000
# VITE_FIREBASE_API_KEY=...
